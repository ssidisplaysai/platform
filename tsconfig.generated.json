{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx"
  },
  "include": [
    "out/generated/**/*Validator.ts",
    "out/generated/**/*.test.ts",
    "out/generated/**/*Repository.ts",
    "out/generated/**/*Service.ts",
    "out/generated/**/*Events.ts",
    "out/generated/**/*.dtos.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
